# Database (PostgreSQL + PostGIS). Use asyncpg driver.
# Docker (from docker compose up): use yarok/yarok
DATABASE_URL=postgresql+asyncpg://yarok:yarok@localhost:5432/yarok

# Redis (for arq task queue)
REDIS_URL=redis://localhost:6379/0

# JWT: generate RS256 key pair for production; leave empty for dev HS256 fallback.
# JWT_PRIVATE_KEY_PEM=
# JWT_PUBLIC_KEY_PEM=

# Field-level encryption: base64 Fernet key (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# ENCRYPTION_KEY=

# S3-compatible storage (optional for MVP)
# S3_ENDPOINT_URL=
# S3_BUCKET=yarok-media
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Optional
# DEBUG=false
# RATE_LIMIT_REPORTS_PER_HOUR=10
# RATE_LIMIT_READS_PER_MINUTE=100

# Debug: ingest client logs to stdout (for Railway production debugging). Set to true only when needed.
# DEBUG_CLIENT_LOGS=false

# Admin: secret for purge-reports and other admin endpoints. Set in production to enable POST/GET /api/v1/admin/purge-reports (X-Admin-Secret header).
# ADMIN_SECRET=

# Password reset (forgot password) — link is sent by email
# PASSWORD_RESET_BASE_URL=https://myapp.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yarok.app
# SMTP_USE_TLS=true
